      mouse      : (0, 0),
      mouse_down : 0,
      view       : (0, 0),
    },
  )(_:, _ok:);
  insert(
    Button {
      bid        : BTN_RESET,
      layer      : 0,
      screen     : (0, 0),
      size       : (0, 0),
      label      : "RESET",
      len        : 5,
      clicked    : 0,
      held       : 0,
      wasdown    : 0,
      mouse      : (0, 0),
      mouse_down : 0,
      view       : (0, 0),
    },
  )(_:, _ok:);
  insert(
    Button {
      bid        : BTN_JUMP,
      layer      : 1,
      screen     : (0, 0),
      size       : (0, 0),
      label      : "-",
      len        : 0,
      clicked    : 0,
      held       : 0,
      wasdown    : 0,
      mouse      : (0, 0),
      mouse_down : 0,
      view       : (0, 0),
    },
  )(_:, _ok:);
}

