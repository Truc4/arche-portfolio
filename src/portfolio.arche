  insert(InfoPanel { bid: SITE_P3, layer: 1, screen: (0,0), size: (0,0), title: "2026", len: 4, sub: "arche, wasm, WIP",      sublen: 16, view: (0,0), iwx: EMB_WX3, iwy: CARD_WY, iprog: 0.0, iw: SITE_W, ih: SITE_H, ipin: 0 })(_:, _ok:);

  insert(InfoBody { bid: INFO_B0, screen: (0,0), size: (0,0), output: "My personal website, in a custom web framework\nand a custom language (Arche).\n\nMove with the arrow keys or the buttons.\nScroll or swipe to pan the world.\n\nLEFT: live demos and a playground.\nRIGHT: a timeline of past projects.\n\nThe native build is a real optimized binary,\nfrom the same source, not a bundled browser.", len: 0, view: (0,0), iwx: 2100.0, iwy: 985.0, iprog: 0.0 , iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: INFO_B1, screen: (0,0), size: (0,0), output: "The whole page is ONE arche program\ncompiled to a single WebAssembly module.\nThe editor above runs that same compiler\nin your browser. Edit it, hit RUN, see output.", len: 0, view: (0,0), iwx:  900.0, iwy: 985.0, iprog: 0.0 , iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: INFO_B2, screen: (0,0), size: (0,0), output: "State lives in typed COLUMN pools (ECS).\nSystems are queries over those columns -\nstructs of arrays the CPU streams through.\nNo objects, no vtables, no allocator churn.", len: 0, view: (0,0), iwx: TAIL_X0, iwy: 985.0, iprog: 0.0 , iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: INFO_B3, screen: (0,0), size: (0,0), output: "A substepped TGS-soft velocity solver:\n8 substeps a frame, boxes and circles.\nThe player is a rigid body too. It tumbles,\ngets shoved, and has to jump the stairs.", len: 0, view: (0,0), iwx: 200.0, iwy: 985.0, iprog: 0.0 , iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: INFO_B5, screen: (0,0), size: (0,0), output: "github.com/Truc4\ncurt.reyes.dev@gmail.com\n\nThis whole site is one arche program.\nThanks for walking through it.", len: 0, view: (0,0), iwx: TAIL_X2, iwy: 985.0, iprog: 0.0 , iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: INFO_B6, screen: (0,0), size: (0,0), output: "A 100% static, ECS-inspired data language.\nA query over {components} is a compile-time\nabstraction that lowers to a column loop.\n\nEffects are flat and marked (eff), never\nnested. Pure funcs compose and dedup the\nlogic that systems cannot nest.\n\nEvery system is a kernel by design. The\nbuild-time mapper finds each column's home\n(Rust-style ownership) and how to fan it.", len: 0, view: (0,0), iwx: TAIL_X1, iwy: 985.0, iprog: 0.0, iw: INFO_W, ih: INFO_H , ipin: 0 })(_:, _ok:);

  insert(InfoBody { bid: SITE_B0, screen: (0,0), size: (0,0), output: "Made with pure HTML, CSS and JS, during\nhigh school. No framework, no build step.\n\nClick the sparkles to start. Arrow keys to\nmove. Enter to go into doors and see my games.", len: 0, view: (0,0), iwx: EMB_WX0, iwy: CARD_WY, iprog: 0.0, iw: SITE_W, ih: SITE_H, ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: SITE_B1, screen: (0,0), size: (0,0), output: "Made a year later, for a more traditional\nportfolio. Built with Bootstrap.\n\nI never finished it.", len: 0, view: (0,0), iwx: EMB_WX1, iwy: CARD_WY, iprog: 0.0, iw: SITE_W, ih: SITE_H, ipin: 0 })(_:, _ok:);
  insert(InfoBody { bid: SITE_B2, screen: (0,0), size: (0,0), output: "Made after working as a web designer.\nBuilt on Wordpress.\n\nShown as a screenshot, not live: its TLS\ncertificate is expired, so a browser will\nnot frame it. Click it to open the site.", len: 0, view: (0,0), iwx: EMB_WX2, iwy: CARD_WY, iprog: 0.0, iw: SITE_W, ih: SITE_H, ipin: 0 })(_:, _ok:);
