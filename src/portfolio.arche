sync_player_ppx :: map (query { ppx, pos })(ppx) {
  ppx = ppx + (pos.x - ppx);
}

rigid_gravity :: map (query { lvel, mi })(lvel) {
  lvel.y = lvel.y + GDT * select(mi.x > 0.0, 1.0, 0.0);
}


project_box :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, ext, bsx, bsy, bhw, bhh })(bsx, bsy, bhw, bhh) eff {
        s := camera.to_screen(
          vec.mk(pos.x, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        bsx = i32(s.x);
        bsy = i32(s.y);
        bhw = i32(ext.x * zoom);
        bhh = i32(ext.y * zoom);
      };
    };
  };
}

project_back :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, kw, kh, ksx, ksy })(ksx, ksy) eff {
        s := camera.to_screen(
          vec.mk(pos.x, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        ksx = i32(s.x) - kw / 2;
        ksy = i32(s.y) - kh / 2;
      };
    };
  };
}

project_solid :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, ext, sflag, ssx, ssy, shw, shh })(ssx, ssy, shw, shh) eff {
        s := camera.to_screen(
          vec.mk(pos.x, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        hw := i32(ext.x * zoom);
        hh := i32(ext.y * zoom);
        ssx = i32(s.x);
        ssy = i32(s.y);
        shw = select(sflag == 1, hw, 0);
        shh = select(sflag == 1, hh, 0);
      };
    };
  };
}

project_ball :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, ext, qsx, qsy, qr })(qsx, qsy, qr) eff {
        s := camera.to_screen(
          vec.mk(pos.x, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        qsx = i32(s.x);
        qsy = i32(s.y);
        qr  = i32(ext.x * zoom);
      };
    };
  };
}

draw_rbox :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { bsx, bsy, bhw, bhh, rot, bcol }) eff {
      diag := bhw + bhh;
      y0   := bsy - diag;
      y1   := bsy + diag;
      x0   := bsx - diag;
      x1   := bsx + diag;
      if (y0 < 0) {
        y0 = 0;
      }
      if (y1 > vh) {
        y1 = vh;
      }
      if (x0 < 0) {
        x0 = 0;
      }
      if (x1 > vw) {
        x1 = vw;
      }
      hw := float(bhw);
      hh := float(bhh);
      yy := y0;
      for (; yy < y1;) {
        xx := x0;
        for (; xx < x1;) {
          dx := float(xx - bsx) + 0.5;
          dy := float(yy - bsy) + 0.5;
          lx := dx * rot.x + dy * rot.y;
          ly := dy * rot.x - dx * rot.y;
          if (vec.absf(lx) < hw && vec.absf(ly) < hh) {
            framebuffer[yy * vw + xx] = bcol;
          }
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

draw_ground :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { ksx, ksy, kw, kh, kcol }) eff {
      y0 := ksy;
      y1 := ksy + kh;
      x0 := ksx;
      x1 := ksx + kw;
      if (y0 < 0) {
        y0 = 0;
      }
      if (y1 > vh) {
        y1 = vh;
      }
      if (x0 < 0) {
        x0 = 0;
      }
      if (x1 > vw) {
        x1 = vw;
      }
      yy := y0;
      for (; yy < y1;) {
        xx := x0;
        for (; xx < x1;) {
          framebuffer[yy * vw + xx] = kcol;
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

draw_solid :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { ssx, ssy, shw, shh, rot }) eff {
      diag := shw + shh;
      y0   := ssy - diag;
      y1   := ssy + diag;
      x0   := ssx - diag;
      x1   := ssx + diag;
      if (y0 < 0) {
        y0 = 0;
      }
      if (y1 > vh) {
        y1 = vh;
      }
      if (x0 < 0) {
        x0 = 0;
      }
      if (x1 > vw) {
        x1 = vw;
      }
      hw := float(shw);
      hh := float(shh);
      yy := y0;
      for (; yy < y1;) {
        xx := x0;
        for (; xx < x1;) {
          dx := float(xx - ssx) + 0.5;
          dy := float(yy - ssy) + 0.5;
          lx := dx * rot.x + dy * rot.y;
          ly := dy * rot.x - dx * rot.y;
          if (vec.absf(lx) < hw && vec.absf(ly) < hh) {
            framebuffer[yy * vw + xx] = BIN;
          }
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

draw_ball :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { qsx, qsy, qr, qcol }) eff {
      r2   := qr * qr;
      yy   := qsy - qr;
      ylim := qsy + qr + 1;
      if (yy < 0) {
        yy = 0;
      }
      if (ylim > vh) {
        ylim = vh;
      }
      for (; yy < ylim;) {
        xx   := qsx - qr;
        xlim := qsx + qr + 1;
        if (xx < 0) {
          xx = 0;
        }
        if (xlim > vw) {
          xlim = vw;
        }
        for (; xx < xlim;) {
          dx := float(xx - qsx) + 0.5;
          dy := float(yy - qsy) + 0.5;
          if (dx * dx + dy * dy < float(r2)) {
            framebuffer[yy * vw + xx] = qcol;
          }
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

input_read :: system eff {
  map (query { handle, gkey })(gkey) eff {
    gfx.key(handle)(k:);
    gkey = k;
  };
}

vinput_clear :: map (query { tax, tjump })(tax, tjump) {
  tax = 0;
  tjump = 0;
}

vinput :: system eff {
  map (query { bid, clicked, held }) eff {
    map (query { tax, tjump })(tax, tjump) eff {
      tax = tax + select(bid == BTN_RIGHT && held == 1, 1, 0) - select(bid == BTN_LEFT && held == 1, 1, 0);
      tjump = select(bid == BTN_JUMP && held == 1, 1, tjump);
    };
  };
}

focus_input :: system eff {
  map (query { handle }) eff {
    gfx.mouse_down(handle)(md:);
    gfx.text_focus(handle)(tf:);
    gfx.axis_x(handle)(dx:);
    map (query { tax, tjump }) eff {
      map (query { fown, fwas, fpress, fcam })(fown, fwas, fpress, fcam) eff {
        press := select(md == 1 && fwas == 0, 1, 0);
        fpress = press;
        fwas = md;
        adopt := select(tf == 1, FOCUS_EDIT, fown);
        base := select(press == 1, FOCUS_WORLD, adopt);
        pad := select(tax != 0, 1, tjump);
        moving := select(dx != 0, 1, pad);
        kb := select(moving == 1, FOCUS_WORLD, base);
        fown = kb;
        cleared := select(press == 1, 0, fcam);
        edit := select(kb == FOCUS_EDIT, PANEL_PLAY + 1, cleared);
        fcam = edit;
      };
    };
  };
}

focus_claim :: system eff {
  map (query { handle }) eff {
    gfx.mouse_x(handle)(mx:);
    gfx.mouse_y(handle)(my:);
    map (query { bid, title, screen, size }) eff {
      map (query { fown, fcam, fpress })(fown, fcam) eff {
        inx := select(mx >= screen.x && mx < screen.x + size.w, 1, 0);
        iny := select(my >= screen.y && my < screen.y + size.h, 1, 0);
        hit := select(fpress == 1 && inx == 1 && iny == 1, 1, 0);
        fcam = select(hit == 1, bid + 1, fcam);
        fown = select(hit == 1 && bid == PANEL_PLAY, FOCUS_EDIT, fown);
      };
    };
  };
}

focus_release :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    gfx.axis_x(handle)(dx:);
    map (query { tax }) eff {
      map (query { ppx }) eff {
        map (query { eye, zoom }) eff {
          map (query { fcam })(fcam) eff {
            sx := (ppx - eye.x) * zoom + float(vw) * 0.5;
            lo := float(PW) + CAM_EDGE;
            hi := float(vw) - float(PW) - CAM_EDGE;
            adx := select(dx != 0, dx, tax);
            atlo := select(sx < lo && adx < 0, 1, 0);
            athi := select(sx > hi && adx > 0, 1, 0);
            out := select(atlo == 1, 1, athi);
            fcam = select(out == 1, 0, fcam);
          };
        };
      };
    };
  };
}

focus_sync :: system eff {
  map (query { handle }) eff {
    map (query { fown }) eff {
      if (fown == FOCUS_WORLD) {
        gfx.release_text(handle)(_:);
      }
    };
  };
}

jump :: system eff {
  map (query { handle }) eff {
    gfx.axis_y(handle)(ay:);
    map (query { tjump }) eff {
    map (query { fown }) eff {
      map (query { ppx, lvel, sup })(lvel) eff {
        grounded := select(sup.y > 0.3, 1.0, 0.0);
        mine := select(fown == FOCUS_WORLD, 1.0, 0.0);
        key_or_pad := select(ay < 0, 1, tjump);
        pressed := select(key_or_pad == 1, 1.0, 0.0) * mine;
        go := grounded * pressed;
        up := 0.0 - JUMP;
        lvel.y = select(go > 0.5, up, lvel.y);
      };
    };
    };
  };
}

walk :: system eff {
  map (query { handle }) eff {
    gfx.axis_x(handle)(dx:);
    map (query { tax }) eff {
    map (query { fown }) eff {
      map (query { ppx, lvel, sup })(lvel) eff {
        adx := select(dx != 0, dx, tax);
        mine := select(fown == FOCUS_WORLD, 1.0, 0.0);
        held := select(adx != 0, 1.0, 0.0) * mine;
        into := float(adx) * sup.x;
        blocked := select(into > 0.3, 1.0, 0.0);
        drive := held * (1.0 - blocked);
        tgt := float(adx) * SPEED;
        grounded := select(sup.y > 0.3, 1.0, 0.0);
        coast := lvel.x * select(grounded > 0.5, WALK_DAMP, 1.0);
        lvel.x = select(drive > 0.5, tgt, coast);
      };
    };
    };
  };
}

pan :: system eff {
  map (query { handle }) eff {
    gfx.scroll(handle)(sc:);
    map (query { eye, zoom })(eye) eff {
      eye.x = eye.x + float(sc) * SCROLL_SPEED;
    };
  };
}

cam_push :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    gfx.axis_x(handle)(dx:);
    gfx.coarse_pointer(handle)(coarse:);
    map (query { tax }) eff {
    map (query { fown, fcam }) eff {
      map (query { ppx }) eff {
        map (query { eye, zoom })(eye) eff {
          adx := select(dx != 0, dx, tax);
          sx := (ppx - eye.x) * zoom + float(vw) * 0.5;
          marg := select(coarse == 1, CAM_MARGIN_M, CAM_MARGIN);
          lo := float(vw) * marg;
          hi := float(vw) - lo;
          past := select(sx < lo, sx - lo, select(sx > hi, sx - hi, 0.0));
          toward := select(past * float(adx) > 0.0, 1.0, 0.0);
          world := select(fown == FOCUS_WORLD, 1.0, 0.0);
          free := select(fcam == 0, 1.0, 0.0);
          eye.x = eye.x + (past / zoom) * CAM_PUSH * toward * world * free;
        };
      };
    };
    };
  };
}

cam_center :: system eff {
  map (query { handle }) eff {
    gfx.coarse_pointer(handle)(coarse:);
    map (query { bid, title, size }) eff {
      map (query { fcam }) eff {
        map (query { eye, zoom })(eye) eff {
          iz := 1.0 / zoom;
          wx := select(bid == PANEL_SAND, 0.0 - SAND_WX, PANEL_WX);
          wy := select(bid == PANEL_SAND, SAND_WY, PANEL_WY);
          cx := wx + float(size.w) * 0.5 * iz;
          cy := wy + float(size.h) * 0.5 * iz;
          ey := select(coarse == 1, EYE_Y0_M, EYE_Y0);
          act := select(fcam == bid + 1, 1, 0);
          idle := select(fcam == 0, 1, 0);
          tx := select(act == 1, cx, eye.x);
          ty := select(act == 1, cy, select(idle == 1, ey, eye.y));
          eye.x = eye.x + (tx - eye.x) * CAM_LERP;
          eye.y = eye.y + (ty - eye.y) * CAM_LERP;
        };
      };
    };
  };
}

clamp_player :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye }) eff {
      map (query { ppx, pos, lvel })(pos, lvel) eff {
        lo := eye.x - float(vw) * 0.5 + float(PW);
        hi := eye.x + float(vw) * 0.5 - float(PW);
        if (pos.x < lo) {
          pos.x = lo;
          if (lvel.x < 0.0) {
            lvel.x = 0.0;
          }
        }
        if (pos.x > hi) {
          pos.x = hi;
          if (lvel.x > 0.0) {
            lvel.x = 0.0;
          }
        }
      };
    };
  };
}

project :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, rw, rh, plx, rx, ry })(rx, ry) eff {
        wx := pos.x + (eye.x - EYE0) * (1.0 - plx);
        s  := camera.to_screen(
          vec.mk(wx, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        rx = i32(s.x) - rw / 2;
        ry = i32(s.y) - rh / 2;
      };
    };
  };
}

project_hill :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { hpx, hpy, hsx, hsy })(hsx, hsy) eff {
        wx := hpx + (eye.x - EYE0) * (1.0 - PAR_HILL);
        s  := camera.to_screen(
          vec.mk(wx, hpy),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        hsx = i32(s.x);
        hsy = i32(s.y);
      };
    };
  };
}

project_round :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { cpx, cpy, cplx, csx, csy })(csx, csy) eff {
        wx := cpx + (eye.x - EYE0) * (1.0 - cplx);
        s  := camera.to_screen(
          vec.mk(wx, cpy),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        csx = i32(s.x);
        csy = i32(s.y);
      };
    };
  };
}

project_player :: system eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { eye, zoom }) eff {
      map (query { pos, prx, pry })(prx, pry) eff {
        s := camera.to_screen(
          vec.mk(pos.x, pos.y),
          eye,
          zoom,
          vec.mk(float(vw) * 0.5, float(vh) * 0.5),
        );
        prx = i32(s.x);
        pry = i32(s.y);
      };
    };
  };
}

draw_hills :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { hsx, hsy, hhw, hht, hcol }) eff {
      apex := hsy - hht;
      yy   := apex;
      if (yy < 0) {
        yy = 0;
      }
      ybase := hsy;
      if (ybase > vh) {
        ybase = vh;
      }
      for (; yy < ybase;) {
        half := hhw * (yy - apex) / hht;
        x0   := hsx - half;
        x1   := hsx + half;
        if (x0 < 0) {
          x0 = 0;
        }
        if (x1 > vw) {
          x1 = vw;
        }
        xx := x0;
        for (; xx < x1;) {
          framebuffer[yy * vw + xx] = hcol;
          xx                        = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

draw_round :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { csx, csy, crad, ccol }) eff {
      r2   := crad * crad;
      yy   := csy - crad;
      ylim := csy + crad + 1;
      if (yy < 0) {
        yy = 0;
      }
      if (ylim > vh) {
        ylim = vh;
      }
      for (; yy < ylim;) {
        xx   := csx - crad;
        xlim := csx + crad + 1;
        if (xx < 0) {
          xx = 0;
        }
        if (xlim > vw) {
          xlim = vw;
        }
        for (; xx < xlim;) {
          dx := xx - csx;
          dy := yy - csy;
          if (dx * dx + dy * dy <= r2) {
            framebuffer[yy * vw + xx] = ccol;
          }
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

draw_player :: system (query { framebuffer })(framebuffer) eff {
  map (query { handle }) eff {
    gfx.dims(handle)(vw:, vh:);
    map (query { prx, pry, rot }) {
      hw   := float(PHALF);
      hh   := float(PHALF);
      diag := PW;
      y0   := pry - diag;
      y1   := pry + diag;
      x0   := prx - diag;
      x1   := prx + diag;
      if (y0 < 0) {
        y0 = 0;
      }
      if (y1 > vh) {
        y1 = vh;
      }
      if (x0 < 0) {
        x0 = 0;
      }
      if (x1 > vw) {
        x1 = vw;
      }
      yy := y0;
      for (; yy < y1;) {
        xx := x0;
        for (; xx < x1;) {
          dx := float(xx - prx) + 0.5;
          dy := float(yy - pry) + 0.5;
          lx := dx * rot.x + dy * rot.y;
          ly := dy * rot.x - dx * rot.y;
          if (vec.absf(lx) < hw && vec.absf(ly) < hh) {
            framebuffer[yy * vw + xx] = PLAYER;
          }
          xx = xx + 1;
        }
        yy = yy + 1;
      }
    };
  };
}

