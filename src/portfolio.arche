S2     :: 0x343a5e;
S3     :: 0x3f4570;
S4     :: 0x4b5183;
S5     :: 0x585f96;
S6     :: 0x656caa;
CLOUD  :: 0x9298cc;
BUSH   :: 0x3f4570;
PLAYER :: 0xe4694e;
BOXA   :: 0x4b5183;
BOXB   :: 0x585f96;
BOXC   :: 0x656caa;
BALLA  :: 0x9298cc;
BALLB  :: 0xd98a5e;
BIN    :: 0x7a82c0;

rw     :: int;
rh     :: int;
rcolor :: int;
rx     :: int;
ry     :: int;
plx    :: float;
ppx    :: float;
prx    :: int;
pry    :: int;
hpx    :: float;
hpy    :: float;
hhw    :: int;
hht    :: int;
hcol   :: int;
hsx    :: int;
hsy    :: int;
cpx    :: float;
cpy    :: float;
crad   :: int;
ccol   :: int;
cplx   :: float;
csx    :: int;
csy    :: int;
handle :: window;
tx     :: int;
ty     :: int;
tsz    :: int;
tcol   :: int;
tlen   :: int;
twx    :: float;
twy    :: float;
tplx   :: float;
bsx    :: int;
bsy    :: int;
bhw    :: int;
bhh    :: int;
bcol   :: int;
qsx    :: int;
qsy    :: int;
qr     :: int;
qcol   :: int;
sflag  :: int;
home(x, y) :: float;
hrot(x, y) :: float;
ssx    :: int;
ssy    :: int;
shw    :: int;
shh    :: int;
gkey   :: int;
fown   :: int;
fwas   :: int;
fpress :: int;
fcam   :: int;
tax    :: int;
tjump  :: int;
kw     :: int;
kh     :: int;
kcol   :: int;
ksx    :: int;
ksy    :: int;

Back  :: arche { pos, kw, kh, kcol, ksx, ksy }
Prop  :: arche { pos, rw, rh, rcolor, plx, rx, ry }
Hill  :: arche { hpx, hpy, hhw, hht, hcol, hsx, hsy }
Round :: arche { cpx, cpy, crad, ccol, cplx, csx, csy }
Box         :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, home, hrot, bsx, bsy, bhw, bhh, bcol }
Ball        :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, home, hrot, qsx, qsy, qr, qcol }
Solid       :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, sflag, ssx, ssy, shw, shh }
Player      :: arche { ppx, prx, pry, pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup }
Focus       :: arche { fown, fwas, fpress, fcam }
Touch       :: arche { tax, tjump }
Window      :: arche { handle, bg, gkey }
Framebuffer :: arche { framebuffer :: [MAXW * H]int }
Sign        :: arche { twx, twy, tplx, tx, ty, tstr :: [64]char, tlen, tsz, tcol }

[4]Back(1);
[12]Prop(6);
[6]Hill(3);
[8]Round(6);
[16]Box(8);
[12]Ball(5);
[16]Solid(7);
[4]RBody;
[2]Player(1);
[2]Focus(1);
[2]Touch(1);
[1]Window ?abort;
[1]Framebuffer(1);
[1]Camera(1);
[12]Sign ?abort;
[1]Closed;

PANEL_WX :: 700.0;
PANEL_WY :: 240.0;
PANEL_W  :: 1100;
PANE_H   :: 360;
BTN_W    :: 200;
BTN_H    :: 76;

PANEL_PLAY :: 0;
PANEL_SAND :: 1;
SAND_WX   :: 1880.0;
SAND_WY   :: 640.0;
SAND_W    :: 1840;
SAND_H    :: 510;

BTN_RUN   :: 0;
BTN_LEFT  :: 1;
BTN_RIGHT :: 2;
BTN_JUMP  :: 3;
BTN_RESET :: 4;
PAD_VMIN  :: 18;
PAD_GAPV  :: 2;
PAD_BOTV  :: 5;
PAD_SIDEV :: 5;

ED_BG  :: 0x0e121b;
ED_FG  :: 0xcdd6f4;
OUT_BG :: 0x11151f;
OUT_FG :: 0xa6e3a1;

Panel  :: arche { bid, layer, screen, size, title :: [24]char, len, sub :: [48]char, sublen, view }
Editor :: arche { screen, size, source :: [4096]char, len, cursor, submit, key, view, bg, fg }
Output :: arche { screen, size, output :: [4096]char, len, view, bg, fg }
Button :: arche {
  bid,
  layer,
  screen,
  size,
  label :: [8]char,
  len,
  clicked,
  held,
  wasdown,
  mouse,
  mouse_down,
  view,
}
[4]Panel ?abort;
[2]Editor ?abort;
[2]Output ?abort;
[8]Button ?abort;

boot :: system eff {
  gfx.open(W, H, "arche-wasm scene")(win:);
  insert(Window { handle: win, bg: CANVAS, gkey: 0 });
}

