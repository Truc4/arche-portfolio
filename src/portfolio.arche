Panel  :: arche { bid, layer, screen, size, title :: [24]char, len, sub :: [48]char, sublen, view }
Editor :: arche { screen, size, source :: [4096]char, len, cursor, submit, key, view, bg, fg }
Output :: arche { bid, screen, size, output :: [4096]char, len, view, bg, fg }
Button :: arche {
  bid,
  layer,
  screen,
  size,
  label :: [8]char,
  len,
  clicked,
  held,
  wasdown,
  mouse,
  mouse_down,
  view,
}
SiteButton :: arche { bid, layer, screen, size, label :: [8]char, len, clicked, held, wasdown, mouse, mouse_down, view, iwx, iwy, iw, ih }
InfoPanel :: arche { bid, layer, screen, size, title :: [24]char, len, sub :: [48]char, sublen, view, iwx, iwy, iprog, iw, ih, ipin }
InfoBody  :: arche { bid, screen, size, output :: [1024]char, len, view, iwx, iwy, iprog, iw, ih, ipin }
Embed     :: arche { bid, screen, size, view, esrc :: [96]char, elen, elink :: [96]char, ellen, ekind, iwx, iwy, iprog, iw, ih, ipin, efocus, epanel, eopen, ebtn }
[4]Panel ?abort;
[2]Editor ?abort;
[2]Output ?abort;
[8]Button ?abort;
[4]SiteButton ?abort;
[16]InfoPanel ?abort;
[12]InfoBody ?abort;
[4]Embed ?abort;

boot :: system eff {
  gfx.open(W, H, "arche-wasm scene")(win:);
  insert(Window { handle: win, bg: CANVAS, gkey: 0 });
}

