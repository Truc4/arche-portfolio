Back  :: arche { pos, kw, kh, kcol, ksx, ksy }
Prop  :: arche { pos, rw, rh, rcolor, plx, rx, ry }
Hill  :: arche { hpx, hpy, hhw, hht, hcol, hsx, hsy }
Wedge :: arche { wpx, wpy, whw, whh, wcol, wdir, wsx, wsy }
Round :: arche { cpx, cpy, crad, ccol, cplx, csx, csy }
Box         :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, awake, home, hrot, bsx, bsy, bhw, bhh, bcol }
Ball        :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, awake, home, hrot, qsx, qsy, qr, qcol }
Solid       :: arche { pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, awake, sflag, ssx, ssy, shw, shh }
Player      :: arche { ppx, prx, pry, pos, lvel, spin, rot, ext, mi, mat, dimp, dang, cor, sup, awake }
Focus       :: arche { fown, fwas, fpress, fcam }
Touch       :: arche { tax, tjump }
Window      :: arche { handle, bg, gkey }
Framebuffer :: arche { framebuffer :: [MAXW * H]int }
Sign        :: arche { twx, twy, tplx, tx, ty, tstr :: [64]char, tlen, tsz, tcol }

[4]Back(1);
[48]Prop(6);
