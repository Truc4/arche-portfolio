#import { gfx camera vec os text ui panel textedit textview button compiler rigid
          "./render" "./physics" "./camview" "./input" "./playground" }

H            :: 1080;
MAXW         :: 4096;
W            :: 1920;
SPEED        :: 9.0;
SCROLL_SPEED :: 1.0;
CAM_MARGIN  :: 0.3;
CAM_MARGIN_M :: 0.42;
CAM_EDGE    :: 6.0;
CAM_PUSH    :: 0.2;
CAM_LERP    :: 0.12;
EYE_Y0      :: 720.0;
EYE_Y0_M    :: 840.0;
EYE0         :: 2100.0;
PAR_HILL     :: 0.5;
PLAYER_Y     :: 1089.0;
PW           :: 102;

WALL_TOP    :: 940.0;
JUMP        :: 13.0;
KEY_UP      :: 1002;
FOCUS_WORLD :: 0;
FOCUS_EDIT  :: 1;
GRAV        :: 0.4;
GDT         :: 0.025;
PHALF       :: 51.0;
BREST       :: 0.12;
BFRIC       :: 0.45;
PFRIC       :: 0.05;
WALK_DAMP   :: 0.80;
BINVI       :: 0.0016;

CANVAS :: 0x12131c;
FLOOR  :: 0x242742;
HILL   :: 0x2c3052;
